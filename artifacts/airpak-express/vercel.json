{
  "buildCommand": "pnpm install --frozen-lockfile=false && BASE_PATH=/ PORT=3000 pnpm --filter @workspace/airpak-express run build",
  "installCommand": "pnpm install",
  "outputDirectory": "dist/public",
  "framework": null,
  "cleanUrls": false,
  "rewrites": [
    { "source": "/signin", "destination": "/signin.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/tracking", "destination": "/tracking.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/payment", "destination": "/payment.html" },
    { "source": "/chat", "destination": "/chat.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/apps/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}