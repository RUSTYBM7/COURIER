
# ============================================
# FIX 11: .env.example - Document all required environment variables
# ============================================

env_example = '''# Airpak Express Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# API SERVER
# ============================================
# Port for the Express API server (default: 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/airpak

# ============================================
# AUTHENTICATION
# ============================================
# REQUIRED in production: Strong random string for session signing
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-strong-random-string-in-production

# ============================================
# EMAIL
# ============================================
# Email provider: sendgrid | mailgun | smtp | console (for dev)
EMAIL_PROVIDER=console

# SendGrid API Key (if using SendGrid)
SENDGRID_API_KEY=SG.xxx

# Mailgun credentials (if using Mailgun)
MAILGUN_DOMAIN=mg.airpak-express.site
MAILGUN_API_KEY=key-xxx

# SMTP settings (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email "from" address
EMAIL_FROM=noreply@airpak-express.site
EMAIL_FROM_NAME="Airpak Express"

# ============================================
# FRONTEND
# ============================================
# Base URL for the frontend (used in email links)
PUBLIC_BASE_URL=https://airpak-express.site

# Vercel deployment domains (comma-separated)
REPLIT_DOMAINS=airpak-express.site,www.airpak-express.site

# ============================================
# PAYMENTS (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================
# EXTERNAL SERVICES
# ============================================
# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (for social login)
APPLE_CLIENT_ID=com.airpak.express
APPLE_TEAM_ID=XXX
APPLE_KEY_ID=XXX
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# ============================================
# SECURITY
# ============================================
# Allowed CORS origins (comma-separated, production only)
CORS_ORIGINS=https://airpak-express.site,https://www.airpak-express.site

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
'''

with open('/mnt/agents/output/airpak-repair/.env.example', 'w') as f:
    f.write(env_example)

